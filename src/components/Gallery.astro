---
interface GalleryItem {
  label: string;
  caption: string;
  credit: string;
  gradient: string;
  span?: 'wide' | 'tall' | 'hero';
}

const items: GalleryItem[] = [
  {
    label: 'La broche',
    caption: 'Viande à la broche, grillée toute la journée',
    credit: 'Plat nº 01',
    gradient: 'linear-gradient(135deg, #8B4513 0%, #D2691E 50%, #A0522D 100%)',
    span: 'hero',
  },
  {
    label: 'Les frites',
    caption: 'L\'accompagnement classique du kebab',
    credit: 'Accompagnement',
    gradient: 'linear-gradient(135deg, #DAA520 0%, #F0C040 50%, #CD853F 100%)',
  },
  {
    label: 'Assiette mixte',
    caption: 'Kebab & brochette, riz ou frites',
    credit: 'Signature',
    gradient: 'linear-gradient(135deg, #6B3A2A 0%, #8B4513 50%, #A0522D 100%)',
    span: 'tall',
  },
  {
    label: 'Pain turc',
    caption: 'Servi chaud avec chaque sandwich',
    credit: 'Sandwich',
    gradient: 'linear-gradient(135deg, #D2B48C 0%, #C4A070 50%, #B8860B 100%)',
  },
  {
    label: 'Tacos',
    caption: 'Viande, frites et sauce fromagère',
    credit: 'Populaire',
    gradient: 'linear-gradient(135deg, #3E2C1F 0%, #6B3A24 50%, #8B4513 100%)',
    span: 'wide',
  },
];
---

<section class="gallery" id="galerie" aria-labelledby="gallery-heading">
  <div class="container">
    <header class="gallery-head" data-reveal>
      <div class="gallery-head-top">
        <p class="eyebrow">Chapitre IV · En Images</p>
        <span class="gallery-count">05 planches</span>
      </div>
      <h2 id="gallery-heading" class="gallery-title">
        Un aperçu <em>de Mosaique</em>
      </h2>
      <p class="gallery-lede">
        Feuilletez — de la broche au dessert, ce qui fait
        le quotidien de la maison.
      </p>
    </header>

    <div class="gallery-grid" data-reveal="scale">
      {items.map((item, i) => (
        <figure class:list={['gallery-item', item.span && `gallery-item--${item.span}`]}>
          <div class="gallery-placeholder" style={`background: ${item.gradient};`}>
            <div class="gallery-placeholder-inner">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            </div>
          </div>
          <figcaption class="gallery-caption">
            <span class="caption-num">{String(i + 1).padStart(2, '0')} / 06</span>
            <span class="caption-label">{item.label}</span>
            <span class="caption-desc">{item.caption}</span>
            <span class="caption-credit">{item.credit}</span>
          </figcaption>
        </figure>
      ))}
    </div>

    <p class="gallery-note" data-reveal>
      <span class="note-rule"></span>
      Photos en préparation — en attendant, venez voir par vous-même
    </p>
  </div>
</section>

<style>
  .gallery {
    padding-block: var(--space-section);
    background: var(--color-charcoal);
  }

  .gallery-head {
    max-width: 48rem;
    margin-bottom: var(--space-xl);
  }

  .gallery-head-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
  }

  .gallery-count {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .gallery-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-cream);
    line-height: 0.95;
    letter-spacing: -0.02em;
  }

  .gallery-title em {
    font-style: italic;
    color: var(--color-amber);
  }

  .gallery-lede {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.55;
    margin-top: var(--space-sm);
    max-width: 36rem;
  }

  /* ─── Bento grid ─── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 220px;
    gap: var(--space-sm);
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: 2px;
    border: 1px solid var(--color-rule);
    cursor: pointer;
  }

  .gallery-item--hero {
    grid-column: span 2;
    grid-row: span 2;
  }

  .gallery-item--wide {
    grid-column: span 2;
  }

  .gallery-item--tall {
    grid-row: span 2;
  }

  .gallery-placeholder {
    width: 100%;
    height: 100%;
    position: relative;
    transition: transform var(--duration-slow) var(--ease-out-expo);
  }

  .gallery-placeholder::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(26, 23, 20, 0.2) 0%, rgba(26, 23, 20, 0.85) 100%);
    transition: background var(--duration-normal) ease;
  }

  .gallery-item:hover .gallery-placeholder {
    transform: scale(1.03);
  }

  .gallery-item:hover .gallery-placeholder::after {
    background: linear-gradient(180deg, rgba(26, 23, 20, 0.1) 0%, rgba(26, 23, 20, 0.75) 100%);
  }

  .gallery-placeholder-inner {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 1;
    color: rgba(245, 240, 232, 0.3);
  }

  /* Editorial caption — positioned at bottom like magazine layout */
  .gallery-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem 1.1rem;
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas:
      'num    credit'
      'label  label'
      'desc   desc';
    gap: 0.2rem 0.5rem;
    z-index: 2;
    color: var(--color-cream);
  }

  .caption-num {
    grid-area: num;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-amber);
    opacity: 0.9;
  }

  .caption-credit {
    grid-area: credit;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(245, 240, 232, 0.6);
  }

  .caption-label {
    grid-area: label;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-top: 0.15rem;
  }

  .caption-desc {
    grid-area: desc;
    font-size: 0.78rem;
    color: rgba(245, 240, 232, 0.75);
    line-height: 1.4;
    max-width: 28ch;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity var(--duration-normal) ease, transform var(--duration-normal) var(--ease-out-expo);
  }

  .gallery-item:hover .caption-desc {
    opacity: 1;
    transform: translateY(0);
  }

  .gallery-item--hero .caption-label {
    font-size: 1.75rem;
  }

  .gallery-item--hero .caption-desc {
    opacity: 1;
    transform: none;
  }

  .gallery-note {
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-top: var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .note-rule {
    width: 2rem;
    height: 1px;
    background: var(--color-amber);
    opacity: 0.5;
  }

  @media (max-width: 900px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 200px;
    }
    .gallery-item--hero,
    .gallery-item--wide {
      grid-column: span 2;
    }
    .gallery-item--tall { grid-row: span 2; }
  }

  @media (max-width: 520px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 220px;
    }
    .gallery-item--hero,
    .gallery-item--wide,
    .gallery-item--tall {
      grid-column: span 1;
      grid-row: span 1;
    }
    .gallery-item--hero { grid-row: span 2; }
    .caption-desc { opacity: 1; transform: none; }
  }
</style>
