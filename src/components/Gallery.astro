---
interface GalleryItem {
  label: string;
  gradient: string;
  span?: 'wide' | 'tall';
}

const items: GalleryItem[] = [
  { label: 'Kebab broche', gradient: 'linear-gradient(135deg, #8B4513 0%, #D2691E 50%, #A0522D 100%)', span: 'wide' },
  { label: 'Frites maison', gradient: 'linear-gradient(135deg, #DAA520 0%, #F0C040 50%, #CD853F 100%)' },
  { label: 'Assiette mixte', gradient: 'linear-gradient(135deg, #6B3A2A 0%, #8B4513 50%, #A0522D 100%)', span: 'tall' },
  { label: 'Notre salle', gradient: 'linear-gradient(135deg, #2D2822 0%, #3E3730 50%, #4A3F35 100%)' },
  { label: 'Pain frais', gradient: 'linear-gradient(135deg, #D2B48C 0%, #C4A070 50%, #B8860B 100%)' },
  { label: 'Baklava maison', gradient: 'linear-gradient(135deg, #CD853F 0%, #DEB887 50%, #D2691E 100%)' },
];
---

<section class="gallery" id="galerie" aria-labelledby="gallery-heading">
  <div class="container">
    <header class="gallery-header" data-reveal>
      <p class="section-subtitle">En images</p>
      <h2 id="gallery-heading" class="section-label">Un aperçu de Mosaique</h2>
    </header>

    <div class="gallery-grid" data-reveal="scale">
      {items.map((item) => (
        <figure class:list={['gallery-item', item.span && `gallery-item--${item.span}`]}>
          <div class="gallery-placeholder" style={`background: ${item.gradient};`}>
            <div class="gallery-placeholder-inner">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
              <span class="gallery-placeholder-text">Photo à venir</span>
            </div>
          </div>
          <figcaption class="gallery-caption">{item.label}</figcaption>
        </figure>
      ))}
    </div>

    <p class="gallery-note" data-reveal>
      Photos en cours de préparation — en attendant, venez voir par vous-même !
    </p>
  </div>
</section>

<style>
  .gallery {
    padding-block: var(--space-section);
    background: var(--color-charcoal);
  }

  .gallery-header {
    margin-bottom: var(--space-lg);
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 200px;
    gap: var(--space-sm);
  }

  .gallery-item {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .gallery-item--wide {
    grid-column: span 2;
  }

  .gallery-item--tall {
    grid-row: span 2;
  }

  .gallery-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .gallery-placeholder::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(26, 23, 20, 0.4);
    transition: background var(--duration-normal) ease;
  }

  .gallery-item:hover .gallery-placeholder::after {
    background: rgba(26, 23, 20, 0.25);
  }

  .gallery-placeholder-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: rgba(245, 240, 232, 0.4);
  }

  .gallery-placeholder-text {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .gallery-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.6rem 0.8rem;
    background: linear-gradient(to top, rgba(26, 23, 20, 0.8), transparent);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-cream);
    z-index: 2;
  }

  .gallery-note {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-style: italic;
    margin-top: var(--space-md);
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 160px;
    }

    .gallery-item--wide {
      grid-column: span 2;
    }
  }

  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 180px;
    }

    .gallery-item--wide,
    .gallery-item--tall {
      grid-column: span 1;
      grid-row: span 1;
    }
  }
</style>
