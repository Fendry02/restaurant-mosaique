---
interface Review {
  name: string;
  text: string;
  stars: number;
  date: string;
}

const heroReview: Review = {
  name: 'Karim B.',
  text: 'Jamais une fausse note, toujours le même niveau. La viande est parfaitement grillée et les sauces relèvent bien les sandwichs. Mon kebab préféré à Lyon, et de loin.',
  stars: 5,
  date: 'Il y a 2 semaines',
};

const reviews: Review[] = [
  {
    name: 'Sophie L.',
    text: 'Très propre, employés chaleureux. Les portions sont très généreuses et les sauces bien dosées. Un bon kebab de quartier, je recommande !',
    stars: 5,
    date: 'Il y a 1 mois',
  },
  {
    name: 'Mehdi A.',
    text: 'Le meilleur kebab de Lyon, je ne dis pas ça à la légère. La viande est grillée et agréablement assaisonnée, le pain est chaud et croustillant.',
    stars: 5,
    date: 'Il y a 3 semaines',
  },
  {
    name: 'Laura M.',
    text: 'Les tacos sont incroyables, la sauce fromagère est généreuse et ça se sent. L\'accueil est toujours au top. Je recommande le tacos double viande !',
    stars: 5,
    date: 'Il y a 1 mois',
  },
  {
    name: 'Youssef K.',
    text: 'L\'assiette mixte est un délice. Riz parfumé, viande tendre, salade fraîche. Et les prix restent très corrects pour le quartier.',
    stars: 4,
    date: 'Il y a 2 mois',
  },
  {
    name: 'Camille D.',
    text: 'On a découvert Mosaique par hasard en se baladant et on y retourne chaque semaine maintenant. Le fondant chocolat en dessert, c\'est la cerise sur le gâteau.',
    stars: 5,
    date: 'Il y a 3 semaines',
  },
];
---

<section class="reviews" id="avis" aria-labelledby="reviews-heading">
  <div class="container">
    <!-- Hero quote block -->
    <div class="reviews-hero" data-reveal>
      <div class="reviews-hero-meta">
        <p class="eyebrow">Chapitre III · Ce qu'ils en disent</p>
        <div class="rating-line">
          <span class="rating-score">4,3</span>
          <div class="rating-stars" aria-label="4.3 sur 5 étoiles">
            {Array.from({length: 4}).map(() => (
              <svg viewBox="0 0 20 20" fill="currentColor" class="star"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.68l5.34-.78z"/></svg>
            ))}
            <svg viewBox="0 0 20 20" class="star star--partial">
              <defs><linearGradient id="star-fill"><stop offset="30%" stop-color="currentColor"/><stop offset="30%" stop-color="transparent"/></linearGradient></defs>
              <path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.68l5.34-.78z" fill="url(#star-fill)" stroke="currentColor" stroke-width="0.8"/>
            </svg>
          </div>
          <span class="rating-count">sur 3 600+ avis Google</span>
        </div>
      </div>

      <blockquote class="reviews-hero-quote">
        <span class="hero-quote-mark" aria-hidden="true">“</span>
        <p id="reviews-heading" class="hero-quote-text">{heroReview.text}</p>
        <footer class="hero-quote-footer">
          <div class="hero-quote-author">
            <span class="author-name">— {heroReview.name}</span>
            <span class="author-date">Google, {heroReview.date}</span>
          </div>
          <a
            href="https://www.google.com/maps/place/Restaurant+mosaique+LYON+3+EME/@45.7526128,4.8519206,17z/"
            target="_blank"
            rel="noopener noreferrer"
            class="hero-quote-link"
          >
            Tous les avis sur Google
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </footer>
      </blockquote>
    </div>

    <hr class="rule rule--warm reviews-divider" />

    <!-- Secondary reviews grid -->
    <div class="reviews-grid" data-reveal-stagger>
      {reviews.map((review, i) => (
        <blockquote class="review-card">
          <span class="review-num">Nº&nbsp;{String(i + 2).padStart(2, '0')}</span>
          <div class="review-stars" aria-hidden="true">
            {Array.from({length: review.stars}).map(() => (
              <svg viewBox="0 0 20 20" fill="currentColor"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.68l5.34-.78z"/></svg>
            ))}
          </div>
          <p class="review-text">{review.text}</p>
          <footer class="review-author">
            <div class="review-avatar" aria-hidden="true">{review.name.charAt(0)}</div>
            <div class="review-meta">
              <span class="review-name">{review.name}</span>
              <span class="review-date">{review.date}</span>
            </div>
          </footer>
        </blockquote>
      ))}
    </div>
  </div>
</section>

<style>
  .reviews {
    padding-block: var(--space-section);
    background: var(--color-charcoal);
  }

  /* ─── Hero quote ─── */
  .reviews-hero {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: var(--space-xl);
    align-items: start;
    margin-bottom: var(--space-xl);
  }

  .reviews-hero-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    padding-top: 0.25rem;
  }

  .rating-line {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .rating-score {
    font-family: var(--font-display);
    font-weight: 700;
    font-style: italic;
    font-size: clamp(3rem, 6vw, 4.5rem);
    line-height: 0.9;
    color: var(--color-amber);
    letter-spacing: -0.02em;
  }

  .rating-stars {
    display: flex;
    gap: 0.15rem;
    color: var(--color-amber);
  }

  .rating-stars .star {
    width: 20px;
    height: 20px;
  }

  .rating-count {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    width: 100%;
    margin-top: 0.25rem;
  }

  .reviews-hero-quote {
    position: relative;
    padding-left: var(--space-md);
    border-left: 1px solid var(--color-rule-warm);
  }

  .hero-quote-mark {
    position: absolute;
    top: -1.5rem;
    left: 0.8rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 7rem;
    color: var(--color-amber);
    line-height: 1;
    opacity: 0.35;
    pointer-events: none;
  }

  .hero-quote-text {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: var(--text-2xl);
    line-height: 1.25;
    color: var(--color-cream);
    letter-spacing: -0.01em;
  }

  .hero-quote-footer {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: var(--space-md);
    margin-top: var(--space-md);
    flex-wrap: wrap;
  }

  .hero-quote-author {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .author-name {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-cream);
  }

  .author-date {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .hero-quote-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: var(--text-sm);
    color: var(--color-amber);
    font-weight: 500;
    transition: gap var(--duration-normal) var(--ease-out-expo);
  }

  .hero-quote-link:hover {
    gap: 0.6rem;
  }

  /* Divider */
  .reviews-divider {
    margin-block: var(--space-lg);
  }

  /* ─── Grid ─── */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--color-rule);
    border-left: 1px solid var(--color-rule);
  }

  .review-card {
    background: transparent;
    border-right: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    padding: var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    transition: background var(--duration-fast) ease;
    position: relative;
  }

  .review-card:hover {
    background: rgba(232, 148, 58, 0.04);
  }

  .review-num {
    position: absolute;
    top: 0.8rem;
    right: 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    opacity: 0.6;
  }

  .review-stars {
    display: flex;
    gap: 0.15rem;
    color: var(--color-amber);
  }

  .review-stars svg {
    width: 14px;
    height: 14px;
  }

  .review-text {
    font-size: var(--text-sm);
    color: var(--color-cream);
    line-height: 1.65;
    flex: 1;
  }

  .review-author {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding-top: var(--space-xs);
    border-top: 1px solid var(--color-rule);
  }

  .review-avatar {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: transparent;
    border: 1px solid var(--color-rule-warm);
    color: var(--color-amber);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 700;
    font-size: var(--text-sm);
    flex-shrink: 0;
  }

  .review-meta {
    display: flex;
    flex-direction: column;
  }

  .review-name {
    font-weight: 500;
    font-size: var(--text-sm);
    color: var(--color-cream);
  }

  .review-date {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  @media (max-width: 960px) {
    .reviews-hero { grid-template-columns: 1fr; gap: var(--space-md); }
    .reviews-hero-quote { border-left: none; padding-left: 0; padding-top: var(--space-md); border-top: 1px solid var(--color-rule-warm); }
    .hero-quote-mark { top: -0.5rem; left: -0.5rem; font-size: 5rem; }
    .reviews-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 640px) {
    .reviews-grid { grid-template-columns: 1fr; }
  }
</style>
