---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-inner container">
    <div class="footer-brand">
      <span class="footer-logo">Mosaique</span>
      <p class="footer-tagline">Kebab & Grillades · Lyon 3</p>
      <div class="footer-social">
        <a href="https://www.instagram.com" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>
        <a href="https://www.facebook.com" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Facebook">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
        </a>
        <a href="https://www.google.com/maps/place/Restaurant+mosaique+LYON+3+EME/@45.7526128,4.8519206,17z/" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Google Maps">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="footer-info">
      <h3 class="footer-heading">Adresse</h3>
      <address class="footer-address">
        42 avenue Félix Faure<br />
        69003 Lyon
      </address>
      <a href="tel:+33478177487" class="footer-phone">04 78 17 74 87</a>
    </div>

    <div class="footer-hours">
      <h3 class="footer-heading">Horaires</h3>
      <p><strong>Lundi — Samedi</strong><br />11h – 23h</p>
      <p><strong>Dimanche</strong><br />Fermé</p>
    </div>
  </div>

  <div class="footer-bottom container">
    <p>&copy; {year} Restaurant Mosaique. Tous droits réservés.</p>
  </div>
</footer>

<style>
  .footer {
    background: #0f0d0b;
    color: rgba(245, 240, 232, 0.6);
    padding-top: var(--space-xl);
    padding-bottom: var(--space-md);
    margin-top: var(--space-section);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid rgba(232, 148, 58, 0.1);
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    font-style: italic;
    color: var(--color-amber);
    display: block;
  }

  .footer-tagline {
    font-size: var(--text-sm);
    margin-top: var(--space-xs);
    color: rgba(245, 240, 232, 0.4);
  }

  .footer-social {
    display: flex;
    gap: 0.5rem;
    margin-top: var(--space-sm);
  }

  .social-link {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid rgba(245, 240, 232, 0.12);
    color: rgba(245, 240, 232, 0.5);
    transition: all var(--duration-fast) ease;
  }

  .social-link:hover {
    border-color: var(--color-amber);
    color: var(--color-amber);
    background: rgba(232, 148, 58, 0.1);
  }

  .footer-heading {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-cream);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-sm);
  }

  .footer-address {
    font-style: normal;
    line-height: 1.7;
  }

  .footer-phone {
    display: inline-block;
    margin-top: var(--space-xs);
    color: rgba(245, 240, 232, 0.4);
    font-weight: 500;
    transition: color var(--duration-fast) ease;
  }

  .footer-phone:hover {
    color: var(--color-amber);
  }

  .footer-hours p {
    line-height: 1.7;
  }

  .footer-hours p + p {
    margin-top: var(--space-xs);
  }

  .footer-hours strong {
    color: rgba(245, 240, 232, 0.8);
    font-weight: 500;
  }

  .footer-bottom {
    padding-top: var(--space-md);
    font-size: var(--text-xs);
    color: rgba(245, 240, 232, 0.25);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: var(--space-md);
      text-align: center;
    }

    .footer-social {
      justify-content: center;
    }
  }
</style>
