    items: [
      { name: 'Kebab', price: '6.50', description: 'Viande à la broche, salade, tomates, oignons, sauce au choix' },
      { name: 'Américain', price: '7.00', description: 'Steak haché, frites, salade, sauce au choix' },
      { name: 'Nuggets', price: '6.50', description: 'Nuggets de poulet, salade, sauce au choix' },
      { name: 'Féta', price: '7.50', description: 'Kebab, féta, salade, tomates, sauce au choix' },
      { name: 'Bacon', price: '7.50', description: 'Kebab, bacon, salade, sauce au choix' },
      { name: 'Burger', price: '7.00', description: 'Steak, salade, tomates, oignons, cheddar, sauce au choix' },
      { name: 'Fish', price: '7.00', description: 'Poisson pané, salade, sauce tartare' },
      { name: 'Köfte', price: '7.00', description: 'Boulettes de viande grillées, salade, sauce au choix' },
      { name: 'Brochette', price: '7.50', description: 'Brochette de poulet ou viande, salade, sauce au choix' },
      { name: 'Galette', price: '7.00', description: 'Galette garnie kebab, salade, sauce au choix' },
    ],
  },
  {
    title: 'Tacos',
    icon: '🌮',
    items: [
      { name: 'Tacos Simple', price: '6.50', description: 'Une viande au choix, frites, sauce fromagère' },
      { name: 'Tacos Double', price: '8.00', description: 'Deux viandes au choix, frites, sauce fromagère', tag: 'Populaire' },
      { name: 'Tacos Triple', price: '9.50', description: 'Trois viandes au choix, frites, sauce fromagère', tag: 'Généreux' },
      { name: 'Tacos Cordon Bleu', price: '8.50', description: 'Cordon bleu, frites, sauce fromagère' },
      { name: 'Tacos Nuggets', price: '8.00', description: 'Nuggets, frites, sauce fromagère' },
    ],
  },
  {
    title: 'Assiettes',
    icon: '🍽️',
    items: [
      { name: 'Kebab', price: '10.00', description: 'Viande à la broche, riz ou frites, salade', tag: 'Populaire' },
      { name: 'Mixte', price: '12.00', description: 'Kebab + brochette, riz ou frites, salade', tag: 'Généreux' },
      { name: 'Adana', price: '11.50', description: 'Brochette Adana épicée, riz ou frites, salade' },
      { name: 'Bouchon', price: '11.00', description: 'Spécialité bouchon lyonnais, riz ou frites, salade' },
      { name: 'Lafi', price: '11.00', description: 'Galette garnie de viande, riz ou frites, salade' },
      { name: 'Brochette', price: '11.00', description: 'Brochettes grillées, riz ou frites, salade' },
      { name: 'Barquettes', price: '8.00', description: 'Frites garnies de viande et sauce' },
    ],
  },
  {
    title: 'Menus',
    icon: '📋',
    items: [
      { name: 'Menu Sandwich', price: '9.50', description: 'Sandwich au choix + frites + boisson', tag: 'Thé offert' },
      { name: 'Menu Tacos', price: '10.50', description: 'Tacos au choix + boisson', tag: 'Thé offert' },
      { name: 'Menu Assiette', price: '13.00', description: 'Assiette au choix + boisson', tag: 'Thé offert' },
      { name: 'Menu Enfant', price: '6.50', description: 'Nuggets ou cordon bleu + frites + boisson' },
    ],
  },
  {
    title: 'Boissons',
    icon: '🥤',
    items: [
      { name: 'Coca-Cola / Fanta / Sprite', price: '2.00', description: '33cl' },
      { name: 'Bouteille 1.5L', price: '3.00', description: 'Coca-Cola, Fanta, Sprite, Oasis' },
      { name: 'Eau minérale', price: '1.50', description: '50cl' },
      { name: 'Ayran', price: '2.00', description: 'Boisson lactée traditionnelle turque' },
      { name: 'Thé turc', price: '1.50', description: 'Offert avec les menus' },
      { name: 'Jus de fruits', price: '2.50', description: 'Orange, pomme, mangue' },
    ],
  },
  {
    title: 'Desserts',
    icon: '🍰',
    items: [
      { name: 'Baklava', price: '3.00', description: 'Pâtisserie feuilletée aux noix et miel', tag: 'Maison' },
      { name: 'Tiramisu', price: '3.50', description: 'Tiramisu maison' },
      { name: 'Fondant chocolat', price: '3.50', description: 'Servi tiède' },
