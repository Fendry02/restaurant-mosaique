    items: [
      { name: 'Fondant chocolat', price: '3.50', description: 'Servi tiède', tag: 'Populaire' },
      { name: 'Glaces', price: '2.50', description: 'Deux boules au choix' },
    ],
  },
];

const pad = (n: number) => String(n).padStart(2, '0');
---

<section class="menu" id="carte" aria-labelledby="menu-heading">
  <div class="container">
    <!-- Editorial header -->
    <header class="menu-header" data-reveal>
      <div class="menu-header-top">
        <p class="eyebrow">La Carte · Chapitre I</p>
        <span class="menu-issue">2026 · Édition courante</span>
      </div>
      <h2 id="menu-heading" class="menu-title">
        La carte, <em>simple et généreuse</em>
      </h2>
      <p class="menu-lede">
        Kebab, tacos, assiettes, grillades — une carte complète à
        <strong>prix doux</strong>, sur place ou à emporter.
      </p>
      <hr class="rule rule--warm" />
    </header>

    <!-- Category tabs -->
    <nav class="menu-tabs" aria-label="Catégories du menu" data-reveal>
      {categories.map((cat, i) => (
        <a href={`#cat-${cat.id}`} class="menu-tab">
          <span class="tab-num">{pad(i + 1)}</span>
          <span class="tab-label">{cat.title}</span>
        </a>
      ))}
    </nav>

    {categories.map((cat, catIndex) => (
      <div class="menu-category" id={`cat-${cat.id}`} data-reveal>
        <header class="category-header">
          <div class="category-head-left">
            <span class="numeral">Chapitre&nbsp;{pad(catIndex + 1)}</span>
            <h3 class="category-title">{cat.title}</h3>
          </div>
          <p class="category-kicker">{cat.kicker}</p>
        </header>

        <ul class="menu-list" role="list" data-reveal-stagger>
          {cat.items.map((item, i) => (
            <li class="menu-item" role="listitem">
              <span class="item-num" aria-hidden="true">Nº {pad(i + 1)}</span>
              <div class="item-body">
                <h4 class="item-name">
                  {item.name}
                  {item.tag && <span class="item-tag">{item.tag}</span>}
                </h4>
                {item.description && <p class="item-desc">{item.description}</p>}
              </div>
              <span class="item-dots" aria-hidden="true"></span>
              <span class="item-price" aria-label={`${item.price} euros`}>
                {item.price}<span class="item-price-cur">€</span>
              </span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<style>
  .menu {
    padding-block: var(--space-section);
    background: var(--color-charcoal);
    position: relative;
  }

  /* Editorial header */
  .menu-header {
    max-width: 48rem;
    margin-bottom: var(--space-xl);
  }

  .menu-header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
    flex-wrap: wrap;
  }

  .menu-issue {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .menu-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-cream);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .menu-title em {
    font-style: italic;
    color: var(--color-amber);
  }

  .menu-lede {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.55;
    max-width: 36rem;
  }

  .menu-lede strong {
    color: var(--color-cream);
    font-weight: 500;
  }

  /* Tabs */
  .menu-tabs {
    display: flex;
    gap: 0;
    margin-bottom: var(--space-xl);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    overflow-x: auto;
    scrollbar-width: none;
  }

  .menu-tabs::-webkit-scrollbar { display: none; }

  .menu-tab {
    flex: 1;
    min-width: max-content;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    transition: all var(--duration-fast) ease;
    border-right: 1px solid var(--color-rule);
    position: relative;
  }

  .menu-tab:last-child { border-right: none; }

  .menu-tab:hover {
    background: rgba(232, 148, 58, 0.06);
    color: var(--color-cream);
  }

  .menu-tab::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 1px;
    background: var(--color-amber);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--duration-normal) var(--ease-out-expo);
  }

  .menu-tab:hover::after { transform: scaleX(1); }

  .tab-num {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    color: var(--color-amber);
    font-weight: 500;
  }

  .tab-label {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  /* Categories */
  .menu-category {
    margin-bottom: var(--space-2xl);
  }

  .menu-category:last-of-type { margin-bottom: 0; }

  .category-header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-md);
    align-items: end;
    padding-bottom: var(--space-md);
    margin-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-rule-warm);
  }

  .category-head-left {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .category-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-cream);
    line-height: 0.9;
    letter-spacing: -0.02em;
  }

  .category-kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-amber);
    padding-bottom: 0.4rem;
  }

  /* List */
  .menu-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    column-gap: var(--space-xl);
    row-gap: 0;
  }

  .menu-item {
    display: grid;
    grid-template-columns: 3rem 1fr auto auto;
    gap: 0.75rem;
    align-items: baseline;
    padding-block: 1.1rem;
    border-bottom: 1px dashed rgba(245, 240, 232, 0.09);
    transition: background var(--duration-fast) ease;
    padding-inline: 0.5rem;
    margin-inline: -0.5rem;
    border-radius: 2px;
  }

  .menu-item:hover {
    background: rgba(232, 148, 58, 0.04);
  }

  .item-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--color-amber);
    opacity: 0.7;
    font-weight: 500;
    align-self: center;
  }

  .item-body {
    min-width: 0;
  }

  .item-name {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-cream);
    line-height: 1.2;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .item-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-amber);
    border: 1px solid var(--color-rule-warm);
    padding: 0.15rem 0.45rem;
    border-radius: 2px;
    white-space: nowrap;
  }

  .item-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
    margin-top: 0.3rem;
  }

  .item-dots {
    border-bottom: 1px dotted rgba(245, 240, 232, 0.18);
    align-self: center;
    min-width: 1rem;
    margin-bottom: 0.15em;
  }

  .item-price {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    font-style: italic;
    color: var(--color-amber);
    white-space: nowrap;
    align-self: center;
  }

  .item-price-cur {
    font-style: normal;
    font-size: 0.7em;
    margin-left: 0.1em;
    opacity: 0.8;
  }

  @media (max-width: 820px) {
    .menu-list { grid-template-columns: 1fr; column-gap: 0; }
    .category-header { grid-template-columns: 1fr; align-items: start; }
    .category-kicker { padding-bottom: 0; }
  }

  @media (max-width: 480px) {
    .menu-item {
      grid-template-columns: 2.5rem 1fr auto;
    }
    .item-dots { display: none; }
  }
</style>
