---

<section class="menu" id="carte" aria-labelledby="menu-heading">
  <div class="container">
    <header class="menu-header" data-reveal>
      <p class="section-subtitle">Notre carte</p>
      <h2 id="menu-heading" class="section-label">Fait maison, fait avec passion</h2>
      <p class="menu-tagline">
        Viande grillée à la broche chaque jour, frites fraîches coupées sur place,<br />
        pain cuit au moment. Thé offert avec chaque menu.
      </p>
    </header>

    <!-- Category tabs for navigation -->
    <nav class="menu-tabs" aria-label="Catégories du menu" data-reveal>
      {categories.map((cat) => (
        <a href={`#cat-${cat.title.toLowerCase().replace(/\s/g, '-')}`} class="menu-tab">
          <span class="tab-icon" aria-hidden="true">{cat.icon}</span>
          <span class="tab-label">{cat.title}</span>
        </a>
      ))}
    </nav>

    {categories.map((cat) => (
      <div class="menu-category" id={`cat-${cat.title.toLowerCase().replace(/\s/g, '-')}`} data-reveal>
        <h3 class="category-title">
          <span class="category-icon" aria-hidden="true">{cat.icon}</span>
          {cat.title}
        </h3>
        <div class="menu-grid" role="list" data-reveal-stagger>
          {cat.items.map((item) => (
            <article class="item-card" role="listitem">
              <div class="item-header">
                <h4 class="item-name">
                  {item.name}
                  {item.tag && <span class="item-tag">{item.tag}</span>}
                </h4>
                <span class="item-dots"></span>
                <span class="item-price" aria-label={`${item.price} euros`}>
                  {item.price}€
                </span>
              </div>
              {item.description && <p class="item-desc">{item.description}</p>}
            </article>
          ))}
          {cat.items.length % 2 !== 0 && <div class="item-card item-card--empty" aria-hidden="true"></div>}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .menu {
    padding-block: var(--space-section);
    background: var(--color-charcoal-mid);
  }

  .menu-header {
    margin-bottom: var(--space-lg);
  }

  .menu-tagline {
    text-align: center;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-top: var(--space-sm);
    line-height: 1.7;
  }

  /* ─── Category tabs ─── */
  .menu-tabs {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: var(--space-xl);
  }

  .menu-tab {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(232, 148, 58, 0.15);
    border-radius: 100px;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    transition: all var(--duration-fast) ease;
    text-decoration: none;
  }

  .menu-tab:hover {
    background: rgba(232, 148, 58, 0.1);
    border-color: rgba(232, 148, 58, 0.3);
    color: var(--color-amber);
  }

  .tab-icon {
    font-size: 1rem;
  }

  .tab-label {
    letter-spacing: 0.02em;
  }

  /* ─── Categories ─── */
  .menu-category {
    margin-bottom: var(--space-xl);
  }

  .menu-category:last-of-type {
    margin-bottom: 0;
  }

  .category-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-cream);
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-xs);
    border-bottom: 1px solid rgba(232, 148, 58, 0.2);
  }

  .category-icon {
    font-size: 1.2em;
  }

  /* ─── Grid ─── */
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: rgba(232, 148, 58, 0.1);
    border: 1px solid rgba(232, 148, 58, 0.1);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .item-card {
    background: var(--color-charcoal-mid);
    padding: var(--space-md);
    transition: background var(--duration-fast) ease;
  }

  .item-card:hover {
    background: var(--color-charcoal-light);
  }

  .item-card--empty {
    background: var(--color-charcoal-mid);
    pointer-events: none;
  }

  .item-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
  }

  .item-name {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-cream);
    line-height: 1.2;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    white-space: nowrap;
  }

  .item-dots {
    flex: 1;
    border-bottom: 1px dotted rgba(245, 240, 232, 0.15);
    min-width: 1rem;
    align-self: center;
    margin-bottom: 0.2em;
  }

  .item-tag {
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--color-amber);
    color: var(--color-charcoal);
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .item-price {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-amber);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .item-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  @media (max-width: 640px) {
    .menu-grid {
      grid-template-columns: 1fr;
    }

    .menu-tabs {
      gap: 0.35rem;
    }

    .menu-tab {
      padding: 0.4rem 0.75rem;
    }
  }
</style>
